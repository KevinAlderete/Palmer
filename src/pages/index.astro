---
import "../styles/styles.css";

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Diseñador visual</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    />
  </head>
  <body>
    <div class="app-shell">
      <header class="app-header">
        <div class="brand-block">
          <div class="brand-mark"><i class="bi bi-easel2-fill"></i></div>
          <div class="brand-text">
            <strong>Diseñador</strong>
            <span>Generador · HTML </span>
          </div>
        </div>

        <input
          id="projectName"
          class="project-name"
          value="Mi diseño"
          aria-label="Nombre del proyecto"
        />

        <div class="top-actions">
          <button
            id="btnUndo"
            class="tool-btn"
            type="button"
            title="Deshacer (Ctrl + Z)"
            ><i class="bi bi-arrow-counterclockwise"></i></button
          >
          <button
            id="btnRedo"
            class="tool-btn"
            type="button"
            title="Rehacer (Ctrl + Y)"
            ><i class="bi bi-arrow-clockwise"></i></button
          >
          <span class="tool-separator"></span>
          <button id="btnImport" class="btn btn-light btn-sm" type="button"
            ><i class="bi bi-box-arrow-in-down"></i> Importar body</button
          >
          <button id="btnPreview" class="btn btn-light btn-sm"
            ><i class="bi bi-eye"></i> Vista previa</button
          >
          <button id="btnExport" class="btn btn-primary btn-sm"
            ><i class="bi bi-file-earmark-code"></i> Exportar HTML</button
          >
        </div>
      </header>

      <main class="editor-layout">
        <aside class="left-sidebar">
          <div class="sidebar-tabs" role="tablist">
            <button
              class="sidebar-tab active"
              data-panel-tab="components"
              type="button"><i class="bi bi-grid"></i> Insertar</button
            >
            <button class="sidebar-tab" data-panel-tab="layers" type="button"
              ><i class="bi bi-layers"></i> Capas</button
            >
          </div>

          <section id="componentsPanel" class="sidebar-content">
            <div class="side-heading">
              <h2>Componentes</h2>
              <span>Arrastra o haz clic</span>
            </div>

            <div class="component-section">
              <h3>Texto y contenido</h3>
              <div class="component-grid">
                <button
                  class="component-card"
                  data-component="heading"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-type-h1"></i><span>Título</span></button
                >
                <button
                  class="component-card"
                  data-component="text"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-text-paragraph"></i><span>Texto</span
                  ></button
                >
                <button
                  class="component-card"
                  data-component="link"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-link-45deg"></i><span>Enlace</span></button
                >
                <button
                  class="component-card"
                  data-component="button"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-cursor-fill"></i><span>Botón</span></button
                >
                <button
                  class="component-card"
                  data-component="image"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-image"></i><span>Imagen</span></button
                >
                <button
                  class="component-card"
                  data-component="icon"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-star-fill"></i><span>Ícono</span></button
                >
                <button
                  class="component-card"
                  data-component="badge"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-bookmark-star-fill"></i><span>Etiqueta</span
                  ></button
                >
              </div>
            </div>

            <div class="component-section">
              <h3>Bloques Bootstrap</h3>
              <div class="component-grid">
                <button
                  class="component-card"
                  data-component="card"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-card-text"></i><span>Tarjeta</span></button
                >
                <button
                  class="component-card"
                  data-component="alert"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-info-circle-fill"></i><span>Alerta</span
                  ></button
                >
                <button
                  class="component-card"
                  data-component="navbar"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-menu-button-wide"></i><span>Navbar</span
                  ></button
                >
                <button
                  class="component-card"
                  data-component="hero"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-stars"></i><span>Hero</span></button
                >
                <button
                  class="component-card"
                  data-component="table"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-table"></i><span>Tabla</span></button
                >
                <button
                  class="component-card"
                  data-component="list"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-list-ul"></i><span>Lista</span></button
                >
                <button
                  class="component-card"
                  data-component="form"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-ui-checks"></i><span>Formulario</span
                  ></button
                >
                <button
                  class="component-card"
                  data-component="input"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-input-cursor-text"></i><span>Input</span
                  ></button
                >
                <button
                  class="component-card"
                  data-component="textarea"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-textarea-t"></i><span>Textarea</span></button
                >
                <button
                  class="component-card"
                  data-component="select"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-menu-down"></i><span>Select</span></button
                >
                <button
                  class="component-card"
                  data-component="checkbox"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-check-square"></i><span>Checkbox</span
                  ></button
                >
                <button
                  class="component-card"
                  data-component="progress"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-bar-chart-line"></i><span>Progreso</span
                  ></button
                >
                <button
                  class="component-card"
                  data-component="video"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-play-btn"></i><span>Video</span></button
                >
                <button
                  class="component-card"
                  data-component="divider"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-dash-lg"></i><span>Separador</span></button
                >
                <button
                  class="component-card"
                  data-component="container"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-square"></i><span>Contenedor</span></button
                >
                <button
                  class="component-card"
                  data-component="line"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-slash-lg"></i><span>Línea</span></button
                >
              </div>
            </div>

            <div class="component-section">
              <h3>Formas</h3>
              <div class="component-grid">
                <button
                  class="component-card"
                  data-component="rectangle"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-square-fill"></i><span>Rectángulo</span
                  ></button
                >
                <button
                  class="component-card"
                  data-component="circle"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-circle-fill"></i><span>Círculo</span></button
                >
              </div>
            </div>

            <div class="component-section">
              <h3>Diseño</h3>
              <div class="component-grid">
                <button
                  class="component-card"
                  data-component="glass"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-window-stack"></i><span>Glass card</span
                  ></button
                >
                <button
                  class="component-card"
                  data-component="stat"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-graph-up-arrow"></i><span>Estadística</span
                  ></button
                >
                <button
                  class="component-card"
                  data-component="pricing"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-credit-card"></i><span>Pricing</span></button
                >
                <button
                  class="component-card"
                  data-component="quote"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-quote"></i><span>Testimonio</span></button
                >
                <button
                  class="component-card"
                  data-component="feature"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-lightning-charge"></i><span>Feature</span
                  ></button
                >
                <button
                  class="component-card"
                  data-component="timeline"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-diagram-3"></i><span>Timeline</span></button
                >
                <button
                  class="component-card"
                  data-component="mockup"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-window-desktop"></i><span>Mockup</span
                  ></button
                >
                <button
                  class="component-card"
                  data-component="notification"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-bell"></i><span>Notificación</span></button
                >
                <button
                  class="component-card"
                  data-component="avatarGroup"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-people-fill"></i><span>Avatares</span
                  ></button
                >
                <button
                  class="component-card"
                  data-component="gradientPanel"
                  draggable="true"
                  type="button"
                  ><i class="bi bi-palette"></i><span>Panel gradiente</span
                  ></button
                >
              </div>
            </div>

            <div class="shortcuts-card">
              <strong><i class="bi bi-keyboard"></i> Atajos</strong>
              <span>Ctrl/Cmd + D duplicar · Supr eliminar</span>
              <span>Ctrl/Cmd + C / V copiar y pegar</span>
              <span>Flechas mover · Shift + flechas mover 10 px</span>
            </div>
          </section>

          <section id="layersPanel" class="sidebar-content d-none">
            <div class="side-heading">
              <h2>Capas</h2>
              <span id="layerCount">0 elementos</span>
            </div>
            <div id="layersList" class="layers-list"></div>
          </section>
        </aside>

        <section class="workspace">
          <div class="workspace-toolbar">
            <div class="toolbar-group">
              <label class="toolbar-label">Lienzo</label>
              <select id="canvasPreset" class="compact-select">
                <option value="desktop">Desktop · 1280 × 720</option>
                <option value="tablet">Tablet · 768 × 900</option>
                <option value="mobile">Móvil · 390 × 844</option>
                <option value="presentation">Presentación · 1366 × 768</option>
                <option value="custom">Libre</option>
              </select>
            </div>

            <div class="toolbar-group canvas-size-controls">
              <label class="canvas-size-field"
                ><span>Ancho</span><input
                  id="canvasWidth"
                  type="number"
                  min="100"
                  step="10"
                /></label
              >
              <label class="canvas-size-field"
                ><span>Alto</span><input
                  id="canvasHeight"
                  type="number"
                  min="100"
                  step="10"
                /></label
              >
            </div>

            <span class="toolbar-divider"></span>

            <div class="toolbar-group">
              <button
                id="btnZoomOut"
                class="tool-btn"
                type="button"
                title="Alejar"><i class="bi bi-dash-lg"></i></button
              >
              <span id="zoomLabel" class="zoom-value">100%</span>
              <button
                id="btnZoomIn"
                class="tool-btn"
                type="button"
                title="Acercar"><i class="bi bi-plus-lg"></i></button
              >
              <button id="btnZoomFit" class="tool-text-btn" type="button"
                >Ajustar</button
              >
            </div>

            <span class="toolbar-divider"></span>

            <div class="toolbar-group">
              <button id="btnGrid" class="tool-text-btn active" type="button"
                ><i class="bi bi-grid-3x3-gap"></i> Cuadrícula</button
              >
              <button id="btnSnap" class="tool-text-btn active" type="button"
                ><i class="bi bi-magnet"></i> Ajustar</button
              >
              <label class="canvas-color"
                ><span>Fondo</span><input
                  id="canvasBg"
                  type="color"
                  value="#ffffff"
                /></label
              >
            </div>

            <div class="workspace-spacer"></div>

            <div class="toolbar-group selected-tools">
              <span id="selectionStatus" class="selection-status"
                >Sin selección</span
              >
              <button
                id="btnSelectAll"
                class="tool-btn"
                type="button"
                title="Seleccionar todo"
                ><i class="bi bi-check2-all"></i></button
              >
              <button
                id="btnDuplicate"
                class="tool-btn"
                type="button"
                title="Duplicar"><i class="bi bi-copy"></i></button
              >
              <button
                id="btnDelete"
                class="tool-btn danger"
                type="button"
                title="Eliminar"><i class="bi bi-trash3"></i></button
              >
            </div>
          </div>

          <div id="canvasScroller" class="canvas-scroller">
            <div id="canvasViewport" class="canvas-viewport">
              <div
                id="canvas"
                class="canvas grid-enabled"
                aria-label="Lienzo de diseño"
              >
              </div>
            </div>
          </div>
        </section>

        <aside class="right-sidebar">
          <div class="inspector-title">
            <div>
              <span class="overline">Inspector</span>
              <h2 id="selectedTitle">Sin selección</h2>
            </div>
            <span id="selectedBadge" class="selection-badge">0</span>
          </div>

          <div id="inspectorEmpty" class="inspector-empty">
            <i class="bi bi-bounding-box"></i>
            <strong>Selecciona un elemento</strong>
            <p>
              Podrás moverlo, redimensionarlo, rotarlo y ajustar cada detalle
              visual.
            </p>
          </div>

          <div id="inspectorMultiple" class="inspector-multiple d-none">
            <div class="multiple-note">
              <i class="bi bi-intersect"></i><span id="multipleText"
                >Varios elementos seleccionados</span
              >
            </div>
            <div class="inspector-section">
              <h3>Alinear</h3>
              <div class="icon-action-grid">
                <button
                  data-align="left"
                  type="button"
                  title="Alinear a la izquierda"
                  ><i class="bi bi-align-start"></i></button
                >
                <button
                  data-align="center"
                  type="button"
                  title="Centrar horizontalmente"
                  ><i class="bi bi-align-center"></i></button
                >
                <button
                  data-align="right"
                  type="button"
                  title="Alinear a la derecha"
                  ><i class="bi bi-align-end"></i></button
                >
                <button data-align="top" type="button" title="Alinear arriba"
                  ><i class="bi bi-align-top"></i></button
                >
                <button
                  data-align="middle"
                  type="button"
                  title="Centrar verticalmente"
                  ><i class="bi bi-align-middle"></i></button
                >
                <button data-align="bottom" type="button" title="Alinear abajo"
                  ><i class="bi bi-align-bottom"></i></button
                >
                <button
                  data-align="distributeX"
                  type="button"
                  title="Distribuir horizontalmente"
                  ><i class="bi bi-distribute-horizontal"></i></button
                >
                <button
                  data-align="distributeY"
                  type="button"
                  title="Distribuir verticalmente"
                  ><i class="bi bi-distribute-vertical"></i></button
                >
              </div>
            </div>
            <div class="inspector-section">
              <h3>Acciones</h3>
              <div class="button-stack">
                <button
                  id="btnGroupFront"
                  class="btn btn-outline-secondary btn-sm"
                  type="button"
                  ><i class="bi bi-front"></i> Traer al frente</button
                >
                <button
                  id="btnGroupBack"
                  class="btn btn-outline-secondary btn-sm"
                  type="button"
                  ><i class="bi bi-back"></i> Enviar al fondo</button
                >
              </div>
            </div>
          </div>

          <div id="inspectorForm" class="d-none">
            <section id="linkSection" class="inspector-section d-none">
              <h3>Enlace</h3>
              <div id="urlGroup" class="form-group d-none">
                <label for="propUrl">URL o enlace</label><input
                  id="propUrl"
                  class="form-control form-control-sm"
                  type="text"
                />
              </div>
              <div class="form-group">
                <label for="propLinkPreset">Estilo rápido</label><select
                  id="propLinkPreset"
                  class="form-control form-control-sm"
                  ><option value="normal">Texto azul</option><option
                    value="subtle">Suave</option
                  ><option value="button">Botón sólido</option><option
                    value="outline">Botón borde</option
                  ><option value="pill">Píldora</option></select
                >
              </div>
              <div class="quad-grid">
                <div class="form-group">
                  <label for="propLinkDecoration">Subrayado</label><select
                    id="propLinkDecoration"
                    class="form-control form-control-sm"
                    ><option value="underline">Sí</option><option value="none"
                      >No</option
                    ></select
                  >
                </div>
                <div class="form-group">
                  <label for="propLinkTarget">Destino</label><label
                    class="checkbox-field"
                    ><input id="propLinkTarget" type="checkbox" /> Nueva pestaña</label
                  >
                </div>
              </div>
            </section>

            <section id="resourceSection" class="inspector-section d-none">
              <h3>Recurso</h3>
              <div id="imageUrlGroup"></div>
            </section>

            <section id="iconSection" class="inspector-section d-none">
              <h3>Ícono</h3>
              <div id="iconGroup" class="form-group d-none">
                <label for="propIcon">Ícono Bootstrap</label><select
                  id="propIcon"
                  class="form-control form-control-sm"
                  ><option value="bi-star-fill">Estrella</option><option
                    value="bi-heart-fill">Corazón</option
                  ><option value="bi-check-circle-fill">Check</option><option
                    value="bi-lightning-charge-fill">Rayo</option
                  ><option value="bi-telephone-fill">Teléfono</option><option
                    value="bi-envelope-fill">Correo</option
                  ><option value="bi-geo-alt-fill">Ubicación</option><option
                    value="bi-person-fill">Persona</option
                  ><option value="bi-calendar-event-fill">Calendario</option
                  ></select
                >
              </div>
            </section>

            <section id="tableSection" class="inspector-section d-none">
              <h3>Tabla</h3>
              <div id="tableCellStatus" class="table-cell-status">
                Selecciona una celda
              </div>
              <div class="table-action-grid">
                <button
                  data-table-action="addRow"
                  type="button"
                  class="btn btn-outline-secondary btn-sm">+ Fila</button
                >
                <button
                  data-table-action="removeRow"
                  type="button"
                  class="btn btn-outline-secondary btn-sm">- Fila</button
                >
                <button
                  data-table-action="addColumn"
                  type="button"
                  class="btn btn-outline-secondary btn-sm">+ Columna</button
                >
                <button
                  data-table-action="removeColumn"
                  type="button"
                  class="btn btn-outline-secondary btn-sm">- Columna</button
                >
              </div>
            </section>

            <section class="inspector-section">
              <h3>Posición y tamaño</h3>
              <div class="quad-grid">
                <div class="form-group">
                  <label for="propX">X</label><input
                    id="propX"
                    class="form-control form-control-sm"
                    type="number"
                    min="0"
                  />
                </div>
                <div class="form-group">
                  <label for="propY">Y</label><input
                    id="propY"
                    class="form-control form-control-sm"
                    type="number"
                    min="0"
                  />
                </div>
                <div class="form-group">
                  <label for="propWidth">Ancho</label><input
                    id="propWidth"
                    class="form-control form-control-sm"
                    type="number"
                    min="1"
                  />
                </div>
                <div class="form-group">
                  <label for="propHeight">Alto</label><input
                    id="propHeight"
                    class="form-control form-control-sm"
                    type="number"
                    min="1"
                  />
                </div>
              </div>
              <div class="form-group mb-0">
                <label for="propRotation"
                  >Rotación <span id="rotationValue">0°</span></label
                ><input
                  id="propRotation"
                  class="custom-range"
                  type="range"
                  min="-180"
                  max="180"
                  step="1"
                />
              </div>
            </section>

            <section class="inspector-section">
              <h3>Apariencia</h3>
              <div class="color-grid">
                <div class="form-group">
                  <label for="propBg">Fondo</label><div class="color-field">
                    <input id="propBgPicker" type="color" /><input
                      id="propBg"
                      class="form-control form-control-sm hex-input"
                      type="text"
                      maxlength="7"
                      placeholder="#FFFFFF"
                      pattern="#[0-9a-fA-F]{6}"
                    />
                  </div>
                </div>
                <div class="form-group">
                  <label for="propColor">Texto</label><div class="color-field">
                    <input id="propColorPicker" type="color" /><input
                      id="propColor"
                      class="form-control form-control-sm hex-input"
                      type="text"
                      maxlength="7"
                      placeholder="#1F2937"
                      pattern="#[0-9a-fA-F]{6}"
                    />
                  </div>
                </div>
                <div class="form-group">
                  <label for="propBorderColor">Borde</label><div
                    class="color-field"
                  >
                    <input id="propBorderPicker" type="color" /><input
                      id="propBorderColor"
                      class="form-control form-control-sm hex-input"
                      type="text"
                      maxlength="7"
                      placeholder="#000000"
                      pattern="#[0-9a-fA-F]{6}"
                    />
                  </div>
                </div>
                <div class="form-group">
                  <label for="propBorderWidth">Grosor</label><input
                    id="propBorderWidth"
                    class="form-control form-control-sm"
                    type="number"
                    min="0"
                    max="50"
                  />
                </div>
              </div>
              <div class="quad-grid">
                <div class="form-group">
                  <label for="propRadius">Radio</label><input
                    id="propRadius"
                    class="form-control form-control-sm"
                    type="number"
                    min="0"
                  />
                </div>
                <div class="form-group">
                  <label for="propOpacity">Opacidad</label><input
                    id="propOpacity"
                    class="form-control form-control-sm"
                    type="number"
                    min="0"
                    max="100"
                  />
                </div>
                <div class="form-group">
                  <label for="propPadding">Padding</label><input
                    id="propPadding"
                    class="form-control form-control-sm"
                    type="text"
                    placeholder="12px"
                  />
                </div>
                <div class="form-group">
                  <label for="propShadow">Sombra</label><select
                    id="propShadow"
                    class="form-control form-control-sm"
                    ><option value="none">Sin sombra</option><option
                      value="soft">Suave</option
                    ><option value="medium">Media</option><option value="strong"
                      >Intensa</option
                    ></select
                  >
                </div>
              </div>
            </section>

            <section id="typographySection" class="inspector-section">
              <h3>Tipografía</h3>
              <div class="quad-grid">
                <div class="form-group">
                  <label for="propFontFamily">Fuente</label><select
                    id="propFontFamily"
                    class="form-control form-control-sm"
                    ><option value="Arial, sans-serif">Arial</option><option
                      value="Helvetica, Arial, sans-serif">Helvetica</option
                    ><option value="Georgia, serif">Georgia</option><option
                      value="'Trebuchet MS', sans-serif">Trebuchet</option
                    ><option value="'Courier New', monospace">Courier</option
                    ></select
                  >
                </div>
                <div class="form-group">
                  <label for="propFontSize">Tamaño</label><select
                    id="propFontSize"
                    class="form-control form-control-sm"
                    ><option value="8">8 px</option><option value="10"
                      >10 px</option
                    ><option value="11">11 px</option><option value="12"
                      >12 px</option
                    ><option value="13">13 px</option><option value="14"
                      >14 px</option
                    ><option value="15">15 px</option><option value="16"
                      >16 px</option
                    ><option value="18">18 px</option><option value="20"
                      >20 px</option
                    ><option value="24">24 px</option><option value="28"
                      >28 px</option
                    ><option value="32">32 px</option><option value="36"
                      >36 px</option
                    ><option value="40">40 px</option><option value="44"
                      >44 px</option
                    ><option value="48">48 px</option><option value="56"
                      >56 px</option
                    ><option value="64">64 px</option><option value="72"
                      >72 px</option
                    ><option value="96">96 px</option></select
                  >
                </div>
                <div class="form-group">
                  <label for="propFontWeight">Peso</label><select
                    id="propFontWeight"
                    class="form-control form-control-sm"
                    ><option value="400">Normal</option><option value="500"
                      >Medio</option
                    ><option value="600">Semibold</option><option value="700"
                      >Bold</option
                    ><option value="800">Extra bold</option></select
                  >
                </div>
                <div class="form-group">
                  <label for="propTextAlign">Alineación</label><select
                    id="propTextAlign"
                    class="form-control form-control-sm"
                    ><option value="left">Izquierda</option><option
                      value="center">Centro</option
                    ><option value="right">Derecha</option></select
                  >
                </div>
              </div>
              <div class="quad-grid">
                <div class="form-group">
                  <label for="propLineHeight">Interlineado</label><input
                    id="propLineHeight"
                    class="form-control form-control-sm"
                    type="number"
                    min="0.5"
                    max="4"
                    step="0.1"
                  />
                </div>
                <div class="form-group">
                  <label for="propLetterSpacing">Espaciado</label><input
                    id="propLetterSpacing"
                    class="form-control form-control-sm"
                    type="number"
                    min="-5"
                    max="20"
                    step="0.1"
                  />
                </div>
                <div class="form-group">
                  <label for="propItalic">Estilo</label><select
                    id="propItalic"
                    class="form-control form-control-sm"
                    ><option value="normal">Normal</option><option
                      value="italic">Cursiva</option
                    ></select
                  >
                </div>
                <div class="form-group">
                  <label for="propObjectFit">Imagen</label><select
                    id="propObjectFit"
                    class="form-control form-control-sm"
                    ><option value="cover">Cubrir</option><option
                      value="contain">Contener</option
                    ><option value="fill">Estirar</option></select
                  >
                </div>
              </div>
            </section>

            <section class="inspector-section">
              <h3>Orden</h3>
              <div class="two-button-row">
                <button
                  id="btnBringFront"
                  type="button"
                  class="btn btn-outline-secondary btn-sm"
                  ><i class="bi bi-front"></i> Al frente</button
                >
                <button
                  id="btnSendBack"
                  type="button"
                  class="btn btn-outline-secondary btn-sm"
                  ><i class="bi bi-back"></i> Al fondo</button
                >
              </div>
            </section>
          </div>
        </aside>
      </main>
    </div>

    <div id="toast" class="app-toast" role="status"></div>

    <div id="previewModal" class="app-modal" aria-hidden="true">
      <div class="app-modal-backdrop" data-close-modal="previewModal"></div>
      <div class="app-modal-dialog preview-dialog">
        <div class="app-modal-header">
          <div>
            <strong>Vista previa</strong><span
              >Así se verá tu diseño exportado.</span
            >
          </div><button
            class="modal-close"
            data-close-modal="previewModal"
            type="button">×</button
          >
        </div>
        <div class="app-modal-body preview-body">
          <iframe id="previewFrame" title="Vista previa del diseño"></iframe>
        </div>
      </div>
    </div>

    <div id="exportModal" class="app-modal" aria-hidden="true">
      <div class="app-modal-backdrop" data-close-modal="exportModal"></div>
      <div class="app-modal-dialog export-dialog">
        <div class="app-modal-header">
          <div>
            <strong>HTML exportado</strong><span
              >Solo contenido interno del body. Bootstrap se reserva para este
              código de salida.</span
            >
          </div><button
            class="modal-close"
            data-close-modal="exportModal"
            type="button">×</button
          >
        </div>
        <div class="app-modal-body">
          <textarea id="exportCode" class="export-code" spellcheck="false"
          ></textarea>
        </div>
        <div class="app-modal-footer">
          <button
            id="btnCopyCode"
            type="button"
            class="btn btn-outline-secondary btn-sm"
            ><i class="bi bi-clipboard"></i> Copiar</button
          ><button
            id="btnDownloadHtml"
            type="button"
            class="btn btn-primary btn-sm"
            ><i class="bi bi-download"></i> Descargar HTML</button
          >
        </div>
      </div>
    </div>

    <div id="importModal" class="app-modal" aria-hidden="true">
      <div class="app-modal-backdrop" data-close-modal="importModal"></div>
      <div class="app-modal-dialog export-dialog">
        <div class="app-modal-header">
          <div>
            <strong>Importar contenido del body</strong><span
              >Pega solo el HTML que iría dentro de &lt;body&gt;. Se convertirá
              en elementos editables.</span
            >
          </div><button
            class="modal-close"
            data-close-modal="importModal"
            type="button">×</button
          >
        </div>
        <div class="app-modal-body">
          <textarea
            id="importCode"
            class="export-code import-code"
            spellcheck="false"
            placeholder="<main>...contenido...</main>"></textarea>
        </div>
        <div class="app-modal-footer">
          <button
            data-close-modal="importModal"
            type="button"
            class="btn btn-outline-secondary btn-sm">Cancelar</button
          ><button
            id="btnApplyImport"
            type="button"
            class="btn btn-primary btn-sm"
            ><i class="bi bi-box-arrow-in-down"></i> Importar al diseñador</button
          >
        </div>
      </div>
    </div>

    <script is:inline src={`${base}js/app.js`}></script>
  </body>
</html>
